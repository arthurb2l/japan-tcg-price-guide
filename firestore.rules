rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own collections (inventory, wishlist, tradelist, cards)
    match /users/{userId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Anonymous card error reports (write-only, no read)
    match /card-reports/{reportId} {
      allow create: if request.resource.data.keys().hasAll(['cardId', 'issueType', 'status'])
        && request.resource.data.issueType in ['wrong_image', 'wrong_price', 'wrong_rarity', 'missing_variant', 'wrong_name', 'other'];
    }
  }
}
