name: Rank Best Packs

on:
  schedule:
    - cron: '0 16 * * 0'  # Sunday 16:00 UTC = Monday 01:00 JST
  workflow_dispatch:

permissions:
  contents: write

jobs:
  rank:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Sort packs by EV and update guide
        run: |
          node << 'SCRIPT'
          const fs = require('fs');
          const data = JSON.parse(fs.readFileSync('data/sets.json', 'utf8'));
          
          // Sort by EV rating descending, take top 5
          const ranked = data.sets
            .filter(s => s.ev_rating)
            .sort((a, b) => b.ev_rating - a.ev_rating)
            .slice(0, 5);
          
          // Build quick ranking string
          const ranking = ranked.map((s, i) => 
            `${i+1}. ${s.name_en} (${s.ev_rating}/5)`
          ).join(' • ');
          
          // Read and update best-packs.html
          let html = fs.readFileSync('guides/best-packs.html', 'utf8');
          
          html = html.replace(
            /<!-- RANKING_START -->[\s\S]*?<!-- RANKING_END -->/,
            `<!-- RANKING_START -->\n<p style="color:#4ecdc4;font-size:.9em;margin-bottom:15px"><strong>Quick Ranking:</strong> ${ranking}</p>\n<!-- RANKING_END -->`
          );
          
          const now = new Date().toISOString().split('T')[0];
          html = html.replace(/Last ranked: [\d-]+/, `Last ranked: ${now}`);
          
          fs.writeFileSync('guides/best-packs.html', html);
          console.log('Updated:', ranking);
          SCRIPT
          
      - name: Commit if changed
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add guides/best-packs.html
          git diff --staged --quiet || git commit -m "Auto-rank best packs by EV 🤖"
          git pull --rebase origin main || true
          git push || echo "Push failed, skipping"
