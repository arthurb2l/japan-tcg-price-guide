  "accuracy_framework": {
    "description": "Source accuracy scores (0-1) reflect how closely the price represents true current market value.",
    "factors": [
      "Stock status: in-stock prices > out-of-stock prices (OOS may be stale)",
      "Transaction type: completed sales > asking prices",
      "Freshness: recently updated > old listings",
      "Specificity: exact card match > fuzzy search results"
    ],
    "scoring_rules": {
      "in_stock_verified": "Full accuracy_score applied",
      "out_of_stock_but_reliable": "accuracy_score × 0.8 (e.g., Yuyutei OOS still accurate)",
      "out_of_stock_unknown_freshness": "accuracy_score × 0.5",
      "stale_data_over_30_days": "accuracy_score × 0.3"
    },
